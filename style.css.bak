* {
  margin: 0;
  padding: 0;
  box-sizing: border-box
}

:root {
  --bg: #F7F3ED;
  --ink: #171310;
  --mid: #4A423C;
  --rule: #D8D0C4;
  --acc: #C4622D;
  --serif: 'Libre Baskerville', Georgia, serif;
  --sans: 'Manrope', sans-serif;
}

@keyframes fadeInUp {
  from {
    opacity: 0;
    transform: translateY(30px);
  }

  to {
    opacity: 1;
    transform: translateY(0);
  }
}

.reveal {
  opacity: 0;
}

.reveal.active {
  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

/* Hero Entrance (JS-Independent) */
.hero-reveal {
  opacity: 0;
  animation: fadeInUp 0.8s cubic-bezier(0.16, 1, 0.3, 1) forwards;
}

.delay-1 {
  animation-delay: 0.2s;
}

.delay-2 {
  animation-delay: 0.4s;
}

.delay-3 {
  animation-delay: 0.6s;
}

body {
  font-family: var(--sans);
  background: var(--bg);
  color: var(--ink);
  -webkit-font-smoothing: antialiased
}

/* NAV */
nav {
  padding: 24px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  position: sticky;
  top: 0;
  background: rgba(247, 243, 237, 0.9);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  z-index: 100;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

@media(min-width:768px) {
  nav {
    padding: 20px 80px
  }
}

.nav-left {
  display: flex;
  align-items: center;
  gap: 48px
}

.nav-links {
  display: none;
  gap: 32px;
  align-items: center
}

@media(min-width:768px) {
  .nav-links {
    display: flex
  }
}

.nav-links a {
  font-size: 11px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--mid);
  text-decoration: none;
  transition: color .15s
}

.nav-links a:hover {
  color: var(--ink)
}

.nav-contact-btn {
  display: none;
  align-items: center;
  gap: 8px;
  border: 1px solid var(--ink);
  color: var(--ink);
  font-size: 10px;
  letter-spacing: .14em;
  text-transform: uppercase;
  padding: 10px 24px;
  border-radius: 30px;
  text-decoration: none;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
}

@media(min-width:768px) {
  .nav-contact-btn {
    display: inline-flex
  }
}

.nav-contact-btn:hover {
  background: var(--ink);
  color: var(--bg);
  transform: translateY(-1px);
}

.mob-btn {
  display: flex;
  flex-direction: column;
  gap: 6px;
  padding: 12px;
  background: none;
  border: none;
  cursor: pointer;
  margin-right: -12px;
  position: relative;
  z-index: 200;
}

.mob-btn span {
  width: 24px;
  height: 1.2px;
  background: var(--ink);
  transition: all .4s cubic-bezier(0.16, 1, 0.3, 1);
  transform-origin: center;
}

.mob-btn.open span:nth-child(1) {
  transform: translateY(7.2px) rotate(45deg);
}

.mob-btn.open span:nth-child(2) {
  opacity: 0;
  transform: scaleX(0);
}

.mob-btn.open span:nth-child(3) {
  transform: translateY(-7.2px) rotate(-45deg);
}

@media(min-width:768px) {
  .mob-btn {
    display: none
  }
}

.mob-nav {
  position: fixed;
  inset: 0;
  background: rgba(247, 243, 237, 0.98);
  z-index: 150;
  display: flex;
  flex-direction: column;
  opacity: 0;
  pointer-events: none;
  transition: all 0.5s cubic-bezier(0.16, 1, 0.3, 1);
}

.mob-nav.open {
  opacity: 1;
  pointer-events: auto;
}

.mob-nav-inner {
  height: 100%;
  display: flex;
  flex-direction: column;
  padding: 120px 40px 60px;
}

.mob-nav-links {
  display: flex;
  flex-direction: column;
  gap: 16px;
  flex-grow: 1;
}

.mob-nav-links a {
  display: flex;
  align-items: center;
  font-size: clamp(42px, 12vw, 56px);
  letter-spacing: -.03em;
  color: var(--ink);
  text-decoration: none;
  font-family: var(--serif);
  transform: translateY(30px);
  opacity: 0;
  transition: all 0.7s cubic-bezier(0.16, 1, 0.3, 1);
  padding: 8px 0;
}

.mob-nav.open .mob-nav-links a {
  transform: translateY(0);
  opacity: 1;
}

.mob-nav.open .mob-nav-links a:nth-child(1) {
  transition-delay: 0.1s;
}

.mob-nav.open .mob-nav-links a:nth-child(2) {
  transition-delay: 0.15s;
}

.mob-nav.open .mob-nav-links a:nth-child(3) {
  transition-delay: 0.2s;
}

.mob-nav.open .mob-nav-links a:nth-child(4) {
  transition-delay: 0.25s;
}

.mob-nav-footer {
  margin-top: auto;
  padding-top: 40px;
  border-top: 1px solid var(--rule);
  display: flex;
  flex-direction: column;
  gap: 32px;
  transform: translateY(20px);
  opacity: 0;
  transition: all 0.8s cubic-bezier(0.16, 1, 0.3, 1) 0.3s;
}

.mob-nav.open .mob-nav-footer {
  transform: translateY(0);
  opacity: 1;
}

.mob-footer-label {
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--mid);
  margin-bottom: 12px;
  font-weight: 500;
}

.mob-footer-val {
  display: block;
  font-size: 18px;
  font-family: var(--serif);
  color: var(--ink);
  text-decoration: none;
  margin-bottom: 4px;
}

.mob-footer-social {
  display: flex;
  gap: 20px;
}

.mob-footer-social a {
  color: var(--ink);
  transition: color 0.3s ease;
  padding: 0 !important;
  /* Override generic mob-nav a if any */
}

.mob-footer-social a:hover {
  color: var(--acc);
}

/* HERO */
.hero {
  position: relative;
  padding: 40px;
  display: flex;
  flex-direction: column;
  justify-content: center;
  overflow: hidden;
  background: url('./photos/hero-bg.webp') no-repeat center center;
  background-size: cover;
  min-height: calc(100vh - 80px);
  z-index: 1;
}

@media(max-width:767px) {
  .hero {
    background: radial-gradient(circle at top left, #FDFBF7 0%, #F7F3ED 100%);
    padding: 120px 32px 80px;
    min-height: 85vh;
  }

  h1 {
    font-size: clamp(42px, 12vw, 56px);
    line-height: 1.0;
    margin-bottom: 24px;
    letter-spacing: -0.04em;
  }

  .h-tag {
    margin-bottom: 20px;
    opacity: 0.6;
  }

  .h-body {
    margin-top: 24px;
    font-size: 16px;
    line-height: 1.6;
    max-width: 100%;
  }

  .h-actions {
    margin-top: 48px;
    flex-direction: column;
    align-items: flex-start;
    gap: 24px;
  }

  .h-btn {
    font-size: 12px;
    padding-bottom: 8px;
  }
}

.hero::before {
  content: '';
  position: absolute;
  inset: 0;
  background: rgba(247, 243, 237, 0.85);
  z-index: -1;
}

.hero>* {
  position: relative;
  z-index: 2;
}

@media(min-width:768px) {
  .hero {
    padding: 60px 80px;
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    min-height: calc(100vh - 88px);
  }
}

.h-left {
  position: relative;
}

@media(min-width:768px) {
  .h-left {
    padding-right: 80px;
  }
}

.h-tag {
  font-size: 10px;
  letter-spacing: .25em;
  text-transform: uppercase;
  color: var(--acc);
  margin-bottom: 24px;
  font-weight: 500;
}

@media(min-width:768px) {
  .h-tag {
    font-size: 11px;
    margin-bottom: 32px
  }
}

h1 {
  font-family: var(--serif);
  font-size: clamp(40px, 8vw, 84px);
  font-weight: 400;
  line-height: 1.05;
  letter-spacing: -.03em;
  margin-bottom: 24px;
}

h1 em {
  font-style: italic;
  display: block;
  color: var(--mid);
  font-weight: 400;
}

.h-body {
  font-size: 15px;
  line-height: 1.8;
  color: var(--mid);
  max-width: 420px;
  margin-top: 28px;
  font-weight: 300;
}

@media(min-width:768px) {
  .h-body {
    font-size: 16px;
  }
}

.h-actions {
  margin-top: 48px;
  display: flex;
  flex-wrap: wrap;
  align-items: center;
  gap: 32px;
}

.h-btn {
  font-size: 11px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--ink);
  text-decoration: none;
  border-bottom: 1.5px solid var(--ink);
  padding-bottom: 4px;
  transition: all 0.3s ease;
  font-weight: 500;
}

.h-btn:hover {
  color: var(--acc);
  border-color: var(--acc);
  transform: translateX(4px);
}

.h-ig {
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--mid);
  text-decoration: none;
  transition: color .15s;
  display: inline-flex;
  align-items: center;
  gap: 6px
}

.h-ig:hover {
  color: var(--acc)
}

.h-right {
  padding-left: 0;
  display: flex;
  flex-direction: column;
  gap: 0;
  position: relative;
}

@media(min-width:768px) {
  .h-right {
    padding-left: 80px
  }
}

.h-stat {
  padding: 24px 0;
  border-bottom: 1px solid rgba(0, 0, 0, 0.05);
}

@media(min-width:768px) {
  .h-stat {
    padding: 36px 0
  }
}

.h-stat:first-child {
  padding-top: 0
}

.h-num {
  font-family: var(--serif);
  font-size: clamp(48px, 10vw, 80px);
  font-weight: 700;
  line-height: 1;
  color: var(--ink);
  letter-spacing: -0.02em;
}

.h-num sup {
  font-size: 40%;
  color: var(--acc);
  vertical-align: super;
  margin-left: 2px;
}

.h-lbl {
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--mid);
  margin-top: 12px;
  font-weight: 500;
}

.h-loc {
  padding-top: 32px;
  font-size: 13px;
  color: var(--mid);
  font-weight: 300;
  line-height: 1.8
}

.h-loc strong {
  display: block;
  font-family: var(--serif);
  font-size: 20px;
  font-weight: 400;
  color: var(--ink);
  margin-bottom: 6px
}

/* DIVIDER */
.divider {
  height: 1px;
  background: var(--rule);
  margin: 0 40px
}

@media(min-width:768px) {
  .divider {
    margin: 0 80px
  }
}

/* PRODUCTS */
.products {
  padding: 40px
}

@media(min-width:768px) {
  .products {
    padding: 60px 80px
  }
}

.sec-label {
  font-size: 11px;
  letter-spacing: .22em;
  text-transform: uppercase;
  color: var(--acc);
  margin-bottom: 16px
}

.sec-title {
  font-family: var(--serif);
  font-size: clamp(28px, 4vw, 48px);
  font-weight: 400;
  letter-spacing: -.01em;
  margin-bottom: 48px
}

.prod-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 24px
}

@media(min-width:640px) {
  .prod-grid {
    grid-template-columns: repeat(2, 1fr)
  }
}

@media(min-width:1024px) {
  .prod-grid {
    grid-template-columns: repeat(3, 1fr)
  }
}

.prod-tile {
  display: flex;
  flex-direction: column;
  gap: 16px;
  text-decoration: none;
  transition: transform 0.3s ease;
  padding: 0;
}

.prod-tile:hover {
  transform: translateY(-4px)
}

.prod-img-wrap {
  position: relative;
  width: 100%;
  aspect-ratio: 4/3;
  overflow: hidden;
  border-radius: 2px;
}

.prod-tile-img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease
}

.prod-overlay {
  position: absolute;
  inset: 0;
  background: rgba(23, 19, 16, 0.6);
  opacity: 0;
  transition: opacity 0.4s ease;
  display: flex;
  align-items: center;
  justify-content: center
}

.prod-overlay span {
  color: #fff;
  font-size: 13px;
  letter-spacing: 0.18em;
  text-transform: uppercase;
  transform: translateY(10px);
  transition: transform 0.4s ease
}

.prod-tile:hover .prod-tile-img {
  transform: scale(1.05)
}

.prod-tile:hover .prod-overlay {
  opacity: 1
}

.prod-tile:hover .prod-overlay span {
  transform: translateY(0)
}

.prod-tile>span {
  font-size: 11px;
  letter-spacing: .16em;
  text-transform: uppercase;
  color: var(--ink);
  text-align: center;
  font-weight: 500;
  display: block;
  width: 100%;
}

/* PORTFOLIO */
.portfolio {
  padding: 40px
}

@media(min-width:768px) {
  .portfolio {
    padding: 60px 80px
  }
}

.port-filters {
  display: flex;
  flex-wrap: wrap;
  gap: 16px;
  margin-bottom: 40px
}

.p-filt {
  background: none;
  border: none;
  font-size: 11px;
  letter-spacing: .14em;
  text-transform: uppercase;
  color: var(--mid);
  cursor: pointer;
  padding: 8px 16px;
  border-radius: 20px;
  transition: all 0.2s
}

.p-filt:hover {
  color: var(--ink)
}

.p-filt.active {
  background: var(--ink);
  color: var(--bg)
}

.port-grid {
  display: grid;
  grid-template-columns: repeat(2, 1fr);
  gap: 16px
}

@media(min-width:640px) {
  .port-grid {
    grid-template-columns: repeat(4, 1fr)
  }
}

@media(min-width:1024px) {
  .port-grid {
    grid-template-columns: repeat(6, 1fr)
  }
}

.port-item {
  position: relative;
  width: 100%;
  aspect-ratio: 4/5;
  overflow: hidden;
  background: #fff;
  border: 1px solid rgba(0, 0, 0, 0.1);
  padding: 4px;
  cursor: zoom-in;
  display: none;
  opacity: 0;
  transform: translateY(10px);
  transition: opacity 0.4s ease, transform 0.4s ease;
}

/* Initial display for LCP (before JS) */
.js-loading .port-item:nth-child(-n+6) {
  display: block;
  opacity: 1;
  transform: translateY(0);
}

.js-active .port-item.visible {
  display: block;
  opacity: 1;
  transform: translateY(0);
}

@media(max-width:767px) {
  .port-item {
    border: none;
    padding: 0;
  }
}

.port-item img {
  width: 100%;
  height: 100%;
  object-fit: cover;
  transition: transform 0.6s ease
}

.port-item:hover img {
  transform: scale(1.02)
}

.port-overlay {
  position: absolute;
  inset: 4px;
  background: rgba(23, 19, 16, 0.7);
  opacity: 0;
  transition: opacity 0.3s ease;
  display: flex;
  align-items: center;
  justify-content: center;
  pointer-events: none;
}

.port-overlay span {
  color: #fff;
  font-size: 12px;
  letter-spacing: 0.15em;
  text-transform: uppercase;
  text-align: center;
  padding: 0 10px;
}

.port-item:hover .port-overlay {
  opacity: 1;
}

.port-load {
  margin-top: 48px;
  display: flex;
  justify-content: center
}

.port-load button {
  background: transparent;
  border: 1px solid var(--ink);
  color: var(--ink);
  font-size: 11px;
  letter-spacing: .18em;
  text-transform: uppercase;
  padding: 14px 32px;
  cursor: pointer;
  transition: all 0.3s cubic-bezier(0.16, 1, 0.3, 1);
  border-radius: 4px;
}

.port-load button:hover {
  background: var(--ink);
  color: var(--bg);
  transform: translateY(-2px);
}

/* LIGHTBOX */
.lightbox {
  position: fixed;
  inset: 0;
  background: rgba(23, 19, 16, 0.95);
  z-index: 9999;
  display: none;
  align-items: center;
  justify-content: center;
  padding: 20px;
  opacity: 0;
  transition: opacity 0.3s
}

.lightbox.active {
  display: flex;
  opacity: 1
}

.lightbox img {
  max-width: 100%;
  max-height: 90vh;
  object-fit: contain
}

.lb-close {
  position: absolute;
  top: 20px;
  right: 30px;
  background: none;
  border: none;
  color: #fff;
  font-size: 40px;
  cursor: pointer;
  font-weight: 300;
  line-height: 1
}

.services {
  padding: 80px 40px;
}

@media(min-width:768px) {
  .services {
    padding: 100px 80px;
  }
}

.svc-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
}

@media(min-width:1024px) {
  .svc-grid {
    grid-template-columns: repeat(2, 1fr);
    gap: 60px;
  }
}

.svc-card {
  display: flex;
  gap: 24px;
  align-items: flex-start
}

.svc-n {
  font-family: var(--serif);
  font-size: 32px;
  line-height: 1;
  color: var(--rule);
  font-weight: 700;
  flex-shrink: 0
}

.svc-content {
  display: flex;
  flex-direction: column;
  gap: 8px
}

.svc-name {
  font-family: var(--serif);
  font-size: 22px;
  font-weight: 400;
  color: var(--ink)
}

.svc-desc {
  font-size: 14px;
  color: var(--mid);
  line-height: 1.7;
  font-weight: 300
}

/* ABOUT */
.about {
  max-width: 1200px;
  margin: 0 auto;
  padding: 40px;
}

@media(min-width:768px) {
  .about {
    padding: 60px 80px;
  }
}



.about-text h2 {
  font-family: var(--serif);
  font-size: clamp(36px, 5vw, 56px);
  font-weight: 400;
  line-height: 1.2;
  letter-spacing: -.01em;
  margin-bottom: 16px;
  color: var(--ink)
}

.about-text p {
  font-size: 16px;
  color: var(--mid);
  line-height: 1.9;
  font-weight: 300;
  margin-bottom: 0
}


.about-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 48px;
  margin-bottom: 0px;
  padding-top: 0px;
  align-items: center;
}

@media(min-width:768px) {
  .about-grid {
    grid-template-columns: 1.8fr 1fr;
    gap: 80px;
    align-items: stretch;
  }
}

.about-text {
  text-align: left;
  padding: 80px 0;
}

@media(min-width:768px) {
  .about-text {
    padding: 100px 0;
  }
}

.about-stats {
  display: flex;
  flex-direction: column;
  justify-content: center;
}

.about-stats .h-right {
  padding-left: 0;
}

/* NAV REDESIGN */
nav {
  padding: 24px 40px;
  display: flex;
  align-items: center;
  justify-content: space-between;
  border-bottom: 1px solid var(--rule);
  position: sticky;
  top: 0;
  background: rgba(247, 243, 237, 0.9);
  backdrop-filter: blur(15px);
  -webkit-backdrop-filter: blur(15px);
  z-index: 100;
}

@media(min-width:768px) {
  nav {
    padding: 20px 80px
  }
}

/* CONTACT */
.contact {
  padding: 100px 40px;
  background: var(--ink);
  color: var(--bg);
  text-align: center;
  position: relative;
}

@media(min-width:768px) {
  .contact {
    padding: 160px 80px;
  }
}

.contact h2 {
  font-family: var(--serif);
  font-size: clamp(32px, 7vw, 64px);
  line-height: 1.1;
  margin-bottom: 60px;
  font-weight: 400;
  color: var(--bg);
}

.contact h2 em {
  font-style: italic;
  color: var(--bg);
  opacity: 0.9;
}

.c-main-btn {
  display: inline-block;
  font-size: 11px;
  letter-spacing: .25em;
  text-transform: uppercase;
  border: 1px solid rgba(247, 243, 237, 0.3);
  color: var(--bg);
  padding: 16px 32px;
  text-decoration: none;
  border-radius: 40px;
  margin-bottom: 100px;
  transition: all 0.4s cubic-bezier(0.16, 1, 0.3, 1);
  font-weight: 500;
}

.c-main-btn:hover {
  border-color: var(--bg);
  background: var(--bg);
  color: var(--ink);
}

.c-info-grid {
  display: grid;
  grid-template-columns: 1fr;
  gap: 60px;
  max-width: 800px;
  margin: 0 auto;
}

@media(min-width:768px) {
  .c-info-grid {
    grid-template-columns: 1fr 1fr;
  }

  .c-email-row {
    grid-column: 1 / -1;
  }
}

.c-item {
  display: flex;
  flex-direction: column;
  align-items: center;
}

.c-label {
  font-size: 10px;
  letter-spacing: .2em;
  text-transform: uppercase;
  color: var(--rule);
  margin-bottom: 20px;
  font-weight: 500;
  opacity: 0.7;
}

.c-val {
  font-size: 20px;
  margin-bottom: 12px;
  font-family: var(--serif);
  line-height: 1.4;
}

.c-val a {
  color: var(--bg);
  text-decoration: none;
  transition: opacity 0.3s ease;
}

.c-val a:hover {
  opacity: 0.7;
}

.c-sub {
  font-size: 13px;
  color: var(--rule);
  line-height: 1.6;
  font-weight: 300;
  opacity: 0.5;
}

.c-copy {
  position: absolute;
  bottom: 40px;
  left: 40px;
  font-size: 10px;
  color: var(--rule);
  letter-spacing: .15em;
  text-transform: uppercase;
  opacity: 0.4;
}

@media(min-width:768px) {
  .c-copy {
    bottom: 60px;
    left: 80px;
  }
}